<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AutoRent.ViewModels"
             x:Class="AutoRent.Views.MainPage"
             Title="AutoRent">

  <ContentPage.BindingContext>
    <vm:MainViewModel />
  </ContentPage.BindingContext>

  <ScrollView>
    <VerticalStackLayout Padding="20" Spacing="16">
      <Label Text="Bienvenido a AutoRent" FontSize="24" HorizontalOptions="Center" />
      <Button Text="Ir a lista de autos" Command="{Binding GoToCarsCommand}" />
    </VerticalStackLayout>
  </ScrollView>

</ContentPage>
