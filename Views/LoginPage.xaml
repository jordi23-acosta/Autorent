<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AutoRent.ViewModels"
             x:Class="AutoRent.Views.LoginPage"
             Title="Iniciar sesión">

  <ContentPage.BindingContext>
    <vm:LoginViewModel />
  </ContentPage.BindingContext>

  <ScrollView>
    <VerticalStackLayout Padding="24" Spacing="12">
      <Label Text="AutoRent" FontSize="28" HorizontalOptions="Center" />
      <Label Text="Bienvenido, inicia sesión o regístrate" FontSize="14" TextColor="{StaticResource Muted}" HorizontalOptions="Center" />

      <Entry Placeholder="Correo electrónico" Text="{Binding Email}" Keyboard="Email" />
      <Entry Placeholder="Contraseña" IsPassword="True" Text="{Binding Password}" />

      <Button Text="Iniciar sesión" Command="{Binding LoginCommand}" />
      <Button Text="Registrarse" Command="{Binding RegisterCommand}" BackgroundColor="Transparent" TextColor="{StaticResource Accent}" />

      <Button Text="Recuperar contraseña" Command="{Binding RecoverCommand}" BackgroundColor="Transparent" TextColor="{StaticResource Muted}" />
    </VerticalStackLayout>
  </ScrollView>

</ContentPage>
