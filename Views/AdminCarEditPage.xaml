<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AutoRent.ViewModels"
             x:Class="AutoRent.Views.AdminCarEditPage"
             Title="Editar auto">

  <ContentPage.BindingContext>
    <vm:AdminViewModel />
  </ContentPage.BindingContext>

  <ScrollView>
    <VerticalStackLayout Padding="12" Spacing="10">
      <Entry Placeholder="Marca" Text="{Binding EditingAuto.Marca}" />
      <Entry Placeholder="Modelo" Text="{Binding EditingAuto.Modelo}" />
      <Entry Placeholder="Año" Text="{Binding EditingAuto.Ano}" Keyboard="Numeric" />
      <Entry Placeholder="Tipo" Text="{Binding EditingAuto.Tipo}" />
      <Entry Placeholder="Precio por hora" Text="{Binding EditingAuto.PrecioHora}" Keyboard="Numeric" />
      <Entry Placeholder="Precio por día" Text="{Binding EditingAuto.PrecioDia}" Keyboard="Numeric" />
      <Button Text="Seleccionar imagen" Command="{Binding PickImageCommand}" />
      <Image Source="{Binding EditingAuto.ImagenUrl}" HeightRequest="120" />

      <HorizontalStackLayout Spacing="8">
        <Button Text="Guardar" Command="{Binding SaveCarCommand}" />
        <Button Text="Eliminar" Command="{Binding DeleteCarCommand}" BackgroundColor="#ef4444" />
      </HorizontalStackLayout>
    </VerticalStackLayout>
  </ScrollView>

</ContentPage>
