<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AutoRent.ViewModels"
             x:Class="AutoRent.Views.CarsPage"
             Title="Autos">

  <ContentPage.BindingContext>
    <vm:CarsViewModel />
  </ContentPage.BindingContext>

  <CollectionView ItemsSource="{Binding Autos}" SelectionMode="Single" x:Name="CarsCollection">
    <CollectionView.ItemTemplate>
      <DataTemplate>
        <Frame Margin="8" CornerRadius="8">
          <Grid ColumnDefinitions="100, *" Padding="8">
            <Image Grid.Column="0" Source="{Binding ImagenUrl}" Aspect="AspectFill" WidthRequest="100" HeightRequest="70" />
            <VerticalStackLayout Grid.Column="1" Spacing="4">
              <Label Text="{Binding Marca}" FontAttributes="Bold" />
              <Label Text="{Binding Modelo}" />
              <Label Text="{Binding Ano}" />
              <Label Text="Tipo: {Binding Tipo}" />
            </VerticalStackLayout>
          </Grid>
        </Frame>
      </DataTemplate>
    </CollectionView.ItemTemplate>
  </CollectionView>

</ContentPage>
