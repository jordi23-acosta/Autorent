<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AutoRent.ViewModels"
             x:Class="AutoRent.Views.CarDetailPage"
             Title="Detalle del auto">

  <ContentPage.BindingContext>
    <vm:CarDetailViewModel />
  </ContentPage.BindingContext>

  <ScrollView>
    <VerticalStackLayout Padding="16" Spacing="12">
      <Image Source="{Binding Auto.ImagenUrl}" HeightRequest="200" Aspect="AspectFill" />
      <Label Text="{Binding Auto.Marca} {Binding Auto.Modelo}" FontSize="20" FontAttributes="Bold" />
      <Label Text="Año: {Binding Auto.Ano}" />
      <Label Text="Tipo: {Binding Auto.Tipo}" />

      <Frame Padding="12" CornerRadius="8">
        <VerticalStackLayout Spacing="8">
          <Label Text="Selecciona tipo de renta" FontAttributes="Bold" />
          <Picker ItemsSource="{Binding RentTypes}" SelectedItem="{Binding SelectedRentType}" />

          <Label Text="Duración" />
          <Stepper Minimum="1" Maximum="168" Increment="1" Value="{Binding Duration}" />
          <Label Text="{Binding DurationLabel}" />

          <Label Text="Total:" FontAttributes="Bold" />
          <Label Text="{Binding TotalFormatted}" FontSize="18" />

          <Button Text="Confirmar renta" Command="{Binding ConfirmCommand}" />
        </VerticalStackLayout>
      </Frame>
    </VerticalStackLayout>
  </ScrollView>

</ContentPage>
