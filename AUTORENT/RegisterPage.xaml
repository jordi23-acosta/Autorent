<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AUTORENT.ViewModels"
             xmlns:converters="clr-namespace:AUTORENT.Converters"
             x:Class="AUTORENT.RegisterPage"
             x:DataType="viewmodels:RegisterViewModel"
             Title="Crear Cuenta"
             BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <!-- Logo -->
            <Image Source="autorent_logo.svg"
                   HeightRequest="80"
                   Margin="0,20,0,30"/>

            <Label Text="Regístrate"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#1565C0"/>

            <Label Text="Crea tu cuenta para empezar"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#666"
                   Margin="0,0,0,20"/>

            <!-- Nombre Completo -->
            <Frame CornerRadius="10" 
                   Padding="0" 
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <Entry Text="{Binding Name}"
                       Placeholder="Nombre completo"
                       PlaceholderColor="#999"
                       TextColor="#333"
                       FontSize="16"
                       Margin="15,10"/>
            </Frame>

            <!-- Email -->
            <Frame CornerRadius="10" 
                   Padding="0" 
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <Entry Text="{Binding Email}"
                       Placeholder="Correo electrónico"
                       Keyboard="Email"
                       PlaceholderColor="#999"
                       TextColor="#333"
                       FontSize="16"
                       Margin="15,10"/>
            </Frame>

            <!-- Teléfono -->
            <Frame CornerRadius="10" 
                   Padding="0" 
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <Entry Text="{Binding Phone}"
                       Placeholder="Teléfono"
                       Keyboard="Telephone"
                       PlaceholderColor="#999"
                       TextColor="#333"
                       FontSize="16"
                       Margin="15,10"/>
            </Frame>

            <!-- Contraseña -->
            <Frame CornerRadius="10" 
                   Padding="0" 
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <Grid ColumnDefinitions="*,Auto" Margin="15,10">
                    <Entry Grid.Column="0"
                           Text="{Binding Password}"
                           Placeholder="Contraseña"
                           IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertedBoolConverter}}"
                           PlaceholderColor="#999"
                           TextColor="#333"
                           FontSize="16"/>
                    <Button Grid.Column="1"
                            Text="{Binding PasswordToggleIcon}"
                            Command="{Binding TogglePasswordCommand}"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            TextColor="#666"
                            Padding="10,0"/>
                </Grid>
            </Frame>

            <!-- Confirmar Contraseña -->
            <Frame CornerRadius="10" 
                   Padding="0" 
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <Grid ColumnDefinitions="*,Auto" Margin="15,10">
                    <Entry Grid.Column="0"
                           Text="{Binding ConfirmPassword}"
                           Placeholder="Confirmar contraseña"
                           IsPassword="{Binding IsConfirmPasswordVisible, Converter={StaticResource InvertedBoolConverter}}"
                           PlaceholderColor="#999"
                           TextColor="#333"
                           FontSize="16"/>
                    <Button Grid.Column="1"
                            Text="{Binding ConfirmPasswordToggleIcon}"
                            Command="{Binding ToggleConfirmPasswordCommand}"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            TextColor="#666"
                            Padding="10,0"/>
                </Grid>
            </Frame>

            <!-- Tipo de Usuario -->
            <Label Text="¿Qué tipo de usuario eres?"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#333"
                   Margin="0,10,0,5"/>

            <Frame CornerRadius="10" 
                   Padding="0" 
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <Picker SelectedIndex="{Binding SelectedUserTypeIndex}"
                        Title="Selecciona tu tipo"
                        TextColor="#333"
                        FontSize="16"
                        Margin="15,10">
                    <Picker.Items>
                        <x:String>Conductor (Rentar autos)</x:String>
                        <x:String>Propietario (Rentar mis autos)</x:String>
                    </Picker.Items>
                </Picker>
            </Frame>

            <!-- Botón Registrarse -->
            <Button Text="Crear Cuenta"
                    Command="{Binding RegisterCommand}"
                    BackgroundColor="#1565C0"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="55"
                    Margin="0,20,0,0"/>

            <!-- Ya tienes cuenta -->
            <HorizontalStackLayout HorizontalOptions="Center" 
                                   Spacing="5"
                                   Margin="0,10,0,20">
                <Label Text="¿Ya tienes cuenta?"
                       TextColor="#666"
                       FontSize="14"/>
                <Label Text="Inicia sesión"
                       TextColor="#1565C0"
                       FontSize="14"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateToLoginCommand}"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
