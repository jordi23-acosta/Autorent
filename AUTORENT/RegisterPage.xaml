<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AUTORENT.RegisterPage"
             Title="Crear Cuenta"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <!-- Logo -->
            <Image Source="autorent_logo.svg"
                   HeightRequest="80"
                   Margin="0,20,0,30"/>

            <Label Text="Regístrate"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#1565C0"/>

            <Label Text="Crea tu cuenta para empezar"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#666"
                   Margin="0,0,0,20"/>

            <!-- Nombre Completo -->
            <Frame CornerRadius="10" 
                   Padding="0" 
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <Entry x:Name="NameEntry"
                       Placeholder="Nombre completo"
                       PlaceholderColor="#999"
                       TextColor="#333"
                       FontSize="16"
                       Margin="15,10"/>
            </Frame>

            <!-- Email -->
            <Frame CornerRadius="10" 
                   Padding="0" 
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <Entry x:Name="EmailEntry"
                       Placeholder="Correo electrónico"
                       Keyboard="Email"
                       PlaceholderColor="#999"
                       TextColor="#333"
                       FontSize="16"
                       Margin="15,10"/>
            </Frame>

            <!-- Teléfono -->
            <Frame CornerRadius="10" 
                   Padding="0" 
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <Entry x:Name="PhoneEntry"
                       Placeholder="Teléfono"
                       Keyboard="Telephone"
                       PlaceholderColor="#999"
                       TextColor="#333"
                       FontSize="16"
                       Margin="15,10"/>
            </Frame>

            <!-- Contraseña -->
            <Frame CornerRadius="10" 
                   Padding="0" 
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <Grid ColumnDefinitions="*,Auto" Margin="15,10">
                    <Entry x:Name="PasswordEntry"
                           Grid.Column="0"
                           Placeholder="Contraseña"
                           IsPassword="True"
                           PlaceholderColor="#999"
                           TextColor="#333"
                           FontSize="16"/>
                    <Button Grid.Column="1"
                            x:Name="TogglePasswordButton"
                            Text="👁"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            TextColor="#666"
                            Padding="10,0"
                            Clicked="OnTogglePasswordClicked"/>
                </Grid>
            </Frame>

            <!-- Confirmar Contraseña -->
            <Frame CornerRadius="10" 
                   Padding="0" 
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <Grid ColumnDefinitions="*,Auto" Margin="15,10">
                    <Entry x:Name="ConfirmPasswordEntry"
                           Grid.Column="0"
                           Placeholder="Confirmar contraseña"
                           IsPassword="True"
                           PlaceholderColor="#999"
                           TextColor="#333"
                           FontSize="16"/>
                    <Button Grid.Column="1"
                            x:Name="ToggleConfirmPasswordButton"
                            Text="👁"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            TextColor="#666"
                            Padding="10,0"
                            Clicked="OnToggleConfirmPasswordClicked"/>
                </Grid>
            </Frame>

            <!-- Tipo de Usuario -->
            <Label Text="¿Qué tipo de usuario eres?"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#333"
                   Margin="0,10,0,5"/>

            <Frame CornerRadius="10" 
                   Padding="0" 
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <Picker x:Name="UserTypePicker"
                        Title="Selecciona tu tipo"
                        TextColor="#333"
                        FontSize="16"
                        Margin="15,10">
                    <Picker.Items>
                        <x:String>Conductor (Rentar autos)</x:String>
                        <x:String>Propietario (Rentar mis autos)</x:String>
                    </Picker.Items>
                </Picker>
            </Frame>

            <!-- Botón Registrarse -->
            <Button x:Name="RegisterButton"
                    Text="Crear Cuenta"
                    BackgroundColor="#1565C0"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="55"
                    Margin="0,20,0,0"
                    Clicked="OnRegisterClicked"/>

            <!-- Ya tienes cuenta -->
            <HorizontalStackLayout HorizontalOptions="Center" 
                                   Spacing="5"
                                   Margin="0,10,0,20">
                <Label Text="¿Ya tienes cuenta?"
                       TextColor="#666"
                       FontSize="14"/>
                <Label Text="Inicia sesión"
                       TextColor="#1565C0"
                       FontSize="14"
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLoginTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
