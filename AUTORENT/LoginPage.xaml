<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AUTORENT.ViewModels"
             xmlns:converters="clr-namespace:AUTORENT.Converters"
             x:Class="AUTORENT.LoginPage"
             x:DataType="viewmodels:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F5">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BusyTextConverter x:Key="BusyTextConverter"/>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            
            <!-- Header con gradiente -->
            <Grid HeightRequest="320" BackgroundColor="#1E88E5">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E88E5" Offset="0.0" />
                        <GradientStop Color="#1565C0" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>
                
                <VerticalStackLayout VerticalOptions="Center" Spacing="15">
                    <!-- Logo SVG -->
                    <Image Source="autorent_logo.svg"
                           HeightRequest="110"
                           WidthRequest="110"
                           HorizontalOptions="Center"/>
                    <Label Text="AUTORENT" 
                           FontSize="36" 
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>
                    <Label Text="Tu plataforma de renta de autos" 
                           FontSize="16"
                           TextColor="#E3F2FD"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <!-- Formulario de Login -->
            <Frame Margin="20,-50,20,20" 
                   Padding="25"
                   CornerRadius="20"
                   HasShadow="True"
                   BackgroundColor="White">
                <VerticalStackLayout Spacing="20">
                    
                    <Label Text="Iniciar Sesión" 
                           FontSize="24" 
                           FontAttributes="Bold"
                           TextColor="#212121"
                           HorizontalOptions="Center"
                           Margin="0,0,0,10"/>

                    <!-- Email -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Email" 
                               FontSize="14" 
                               TextColor="#757575"
                               FontAttributes="Bold"/>
                        <Frame Padding="0" 
                               CornerRadius="10" 
                               BorderColor="#E0E0E0"
                               HasShadow="False">
                            <Entry Text="{Binding Email}"
                                   Placeholder="tu@email.com"
                                   Keyboard="Email"
                                   TextColor="#212121"
                                   PlaceholderColor="#9E9E9E"
                                   Margin="15,0"/>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Password -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Contraseña" 
                               FontSize="14" 
                               TextColor="#757575"
                               FontAttributes="Bold"/>
                        <Frame Padding="0" 
                               CornerRadius="10" 
                               BorderColor="#E0E0E0"
                               HasShadow="False">
                            <Grid ColumnDefinitions="*,Auto" Margin="15,0">
                                <Entry Grid.Column="0"
                                       Text="{Binding Password}"
                                       Placeholder="••••••••"
                                       IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertedBoolConverter}}"
                                       TextColor="#212121"
                                       PlaceholderColor="#9E9E9E"/>
                                <Button Grid.Column="1"
                                        Text="{Binding PasswordToggleIcon}"
                                        Command="{Binding TogglePasswordCommand}"
                                        FontSize="20"
                                        BackgroundColor="Transparent"
                                        TextColor="#666"
                                        Padding="10,0"/>
                            </Grid>
                        </Frame>
                    </VerticalStackLayout>

                    <!-- Olvidé mi contraseña -->
                    <Label Text="¿Olvidaste tu contraseña?" 
                           FontSize="13"
                           TextColor="#1E88E5"
                           HorizontalOptions="End"
                           Margin="0,-10,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>

                    <!-- Botón de Login -->
                    <Button Text="{Binding IsBusy, Converter={StaticResource BusyTextConverter}}"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                            BackgroundColor="#1E88E5"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="55"
                            FontSize="16"
                            FontAttributes="Bold"
                            Margin="0,10,0,0"/>

                    <!-- Divider -->
                    <Grid ColumnDefinitions="*,Auto,*" 
                          ColumnSpacing="10" 
                          Margin="0,10,0,10">
                        <BoxView Grid.Column="0" 
                                 HeightRequest="1" 
                                 BackgroundColor="#E0E0E0"
                                 VerticalOptions="Center"/>
                        <Label Grid.Column="1" 
                               Text="o" 
                               TextColor="#757575"
                               FontSize="14"/>
                        <BoxView Grid.Column="2" 
                                 HeightRequest="1" 
                                 BackgroundColor="#E0E0E0"
                                 VerticalOptions="Center"/>
                    </Grid>

                    <!-- Botón de Registro -->
                    <Button Text="Crear Cuenta Nueva"
                            Command="{Binding NavigateToRegisterCommand}"
                            BackgroundColor="Transparent"
                            TextColor="#1E88E5"
                            BorderColor="#1E88E5"
                            BorderWidth="2"
                            CornerRadius="10"
                            HeightRequest="55"
                            FontSize="16"
                            FontAttributes="Bold"/>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
