<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AUTORENT.Pages.OwnerEarningsPage"
             Title="Mis Ganancias"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="Auto,*" Padding="0">
        
        <!-- Header -->
        <BoxView Grid.Row="0" HeightRequest="120" BackgroundColor="#4CAF50"/>
        <VerticalStackLayout Grid.Row="0" Padding="20" VerticalOptions="Center">
            <Label Text="Mis Ganancias" 
                   FontSize="28" 
                   FontAttributes="Bold"
                   TextColor="White"/>
            <Label Text="Resumen de ingresos" 
                   FontSize="14"
                   TextColor="#E8F5E9"
                   Margin="0,5,0,0"/>
        </VerticalStackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="1" Margin="0,-20,0,0">
            <VerticalStackLayout Spacing="15" Padding="20">

                <!-- Tarjeta de ganancias totales -->
                <Frame Padding="25" 
                       CornerRadius="20" 
                       BackgroundColor="White"
                       HasShadow="True">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Ganancias Totales" 
                               FontSize="14" 
                               TextColor="#757575"/>
                        <Label Text="$12,450" 
                               FontSize="42" 
                               FontAttributes="Bold"
                               TextColor="#4CAF50"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                <Label Text="Este mes" FontSize="12" TextColor="#757575"/>
                                <Label Text="$2,500" FontSize="18" FontAttributes="Bold" TextColor="#212121"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                <Label Text="Pendiente" FontSize="12" TextColor="#757575"/>
                                <Label Text="$450" FontSize="18" FontAttributes="Bold" TextColor="#FF9800"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Estadísticas mensuales -->
                <Label Text="Últimos 6 Meses" 
                       FontSize="18" 
                       FontAttributes="Bold"
                       TextColor="#212121"
                       Margin="0,10,0,5"/>

                <Frame Padding="20" 
                       CornerRadius="15" 
                       BackgroundColor="White"
                       HasShadow="True">
                    <VerticalStackLayout Spacing="15">
                        
                        <Grid ColumnDefinitions="*,Auto" RowSpacing="15">
                            <Label Grid.Column="0" Text="Mayo 2026" FontSize="14" TextColor="#212121" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="$2,500" FontSize="16" FontAttributes="Bold" TextColor="#4CAF50" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Abril 2026" FontSize="14" TextColor="#212121" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="$3,200" FontSize="16" FontAttributes="Bold" TextColor="#4CAF50" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Marzo 2026" FontSize="14" TextColor="#212121" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="$2,100" FontSize="16" FontAttributes="Bold" TextColor="#4CAF50" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Febrero 2026" FontSize="14" TextColor="#212121" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="$1,850" FontSize="16" FontAttributes="Bold" TextColor="#4CAF50" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Enero 2026" FontSize="14" TextColor="#212121" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="$1,600" FontSize="16" FontAttributes="Bold" TextColor="#4CAF50" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Diciembre 2025" FontSize="14" TextColor="#212121" VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="$1,200" FontSize="16" FontAttributes="Bold" TextColor="#4CAF50" VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Frame>

                <!-- Vehículos más rentables -->
                <Label Text="Vehículos Más Rentables" 
                       FontSize="18" 
                       FontAttributes="Bold"
                       TextColor="#212121"
                       Margin="0,10,0,5"/>

                <Frame Padding="15" 
                       CornerRadius="15" 
                       BackgroundColor="White"
                       HasShadow="True">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="15">
                        
                        <HorizontalStackLayout Grid.Row="0" Spacing="15">
                            <Frame WidthRequest="60" HeightRequest="60" CornerRadius="10" Padding="0" BackgroundColor="#FFF3E0" HasShadow="False">
                                <Label Text="🚐" FontSize="30" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Frame>
                            <VerticalStackLayout Spacing="5" VerticalOptions="Center" HorizontalOptions="FillAndExpand">
                                <Label Text="Honda CR-V 2024" FontSize="16" FontAttributes="Bold" TextColor="#212121"/>
                                <Label Text="18 rentas • $48/día" FontSize="12" TextColor="#757575"/>
                            </VerticalStackLayout>
                            <Label Text="$864" FontSize="18" FontAttributes="Bold" TextColor="#4CAF50" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <BoxView Grid.Row="1" HeightRequest="1" BackgroundColor="#E0E0E0"/>

                        <HorizontalStackLayout Grid.Row="2" Spacing="15">
                            <Frame WidthRequest="60" HeightRequest="60" CornerRadius="10" Padding="0" BackgroundColor="#E3F2FD" HasShadow="False">
                                <Label Text="🚙" FontSize="30" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Frame>
                            <VerticalStackLayout Spacing="5" VerticalOptions="Center" HorizontalOptions="FillAndExpand">
                                <Label Text="Toyota Corolla 2024" FontSize="16" FontAttributes="Bold" TextColor="#212121"/>
                                <Label Text="24 rentas • $35/día" FontSize="12" TextColor="#757575"/>
                            </VerticalStackLayout>
                            <Label Text="$840" FontSize="18" FontAttributes="Bold" TextColor="#4CAF50" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                    </Grid>
                </Frame>

                <!-- Botón de retiro -->
                <Button Text="Solicitar Retiro de Fondos"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        CornerRadius="15"
                        HeightRequest="55"
                        FontSize="16"
                        FontAttributes="Bold"
                        Margin="0,20,0,30"
                        Clicked="OnWithdrawClicked"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
