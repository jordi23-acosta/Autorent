<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AUTORENT.Pages.OwnerEarningsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F9FA">

    <Grid RowDefinitions="*">
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- Header con gradiente VERDE (ganancias) -->
                <Grid HeightRequest="280">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#43A047" Offset="0.0" />
                            <GradientStop Color="#2E7D32" Offset="0.5" />
                            <GradientStop Color="#1B5E20" Offset="1.0" />
                        </LinearGradientBrush>
                    </Grid.Background>

                    <!-- Círculos decorativos -->
                    <Ellipse Fill="#FFFFFF" 
                             Opacity="0.1"
                             WidthRequest="200" 
                             HeightRequest="200"
                             HorizontalOptions="End"
                             VerticalOptions="Start"
                             Margin="0,-50,-50,0"/>
                    <Ellipse Fill="#FFFFFF" 
                             Opacity="0.08"
                             WidthRequest="150" 
                             HeightRequest="150"
                             HorizontalOptions="Start"
                             VerticalOptions="End"
                             Margin="-30,0,0,-30"/>

                    <Grid ColumnDefinitions="Auto,*" 
                          RowDefinitions="Auto,*"
                          Padding="20,50,20,20">

                        <!-- Botón regreso -->
                        <Border Grid.Row="0" Grid.Column="0"
                                StrokeThickness="0"
                                BackgroundColor="#33FFFFFF"
                                WidthRequest="42"
                                HeightRequest="42">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="21"/>
                            </Border.StrokeShape>
                            <Label Text="←"
                                   FontSize="22"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnBackTapped"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>

                        <!-- Total de ganancias -->
                        <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" 
                                             VerticalOptions="Center"
                                             Spacing="6"
                                             Margin="0,30,0,0">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Label Text="💰" FontSize="20"/>
                                <Label Text="GANANCIAS TOTALES" 
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#C8E6C9"
                                       CharacterSpacing="2"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label HorizontalOptions="Start">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="$" 
                                              FontSize="28" 
                                              TextColor="White"
                                              FontAttributes="Bold"/>
                                        <Span Text="12,450" 
                                              FontSize="48" 
                                              TextColor="White"
                                              FontAttributes="Bold"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label Text="↗ +24% vs mes anterior" 
                                   FontSize="13"
                                   TextColor="#A5D6A7"
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Grid>
                </Grid>

                <!-- Stats Cards -->
                <Grid ColumnDefinitions="*,*" 
                      ColumnSpacing="10"
                      Margin="20,-40,20,15"
                      HeightRequest="100">

                    <Border Grid.Column="0"
                            StrokeThickness="0"
                            BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.12" Radius="12" Offset="0,3"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="3" 
                                             VerticalOptions="Center"
                                             Padding="12">
                            <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                                <Label Text="📈" FontSize="18"/>
                                <Label Text="Este mes" 
                                       FontSize="11"
                                       TextColor="#757575"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="$2,500" 
                                   FontSize="22" 
                                   FontAttributes="Bold"
                                   TextColor="#43A047"
                                   HorizontalOptions="Center"/>
                            <Label Text="↗ +12%" 
                                   FontSize="10"
                                   TextColor="#43A047"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            StrokeThickness="0"
                            BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.12" Radius="12" Offset="0,3"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="3" 
                                             VerticalOptions="Center"
                                             Padding="12">
                            <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                                <Label Text="⏳" FontSize="18"/>
                                <Label Text="Pendiente" 
                                       FontSize="11"
                                       TextColor="#757575"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="$450" 
                                   FontSize="22" 
                                   FontAttributes="Bold"
                                   TextColor="#FF9800"
                                   HorizontalOptions="Center"/>
                            <Label Text="2 rentas" 
                                   FontSize="10"
                                   TextColor="#9E9E9E"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Sección: Histórico Mensual -->
                <Label Text="HISTÓRICO MENSUAL" 
                       FontSize="12" 
                       FontAttributes="Bold"
                       TextColor="#9E9E9E"
                       CharacterSpacing="2"
                       Margin="25,5,20,8"/>

                <Border Margin="20,0,20,15" 
                        Padding="0"
                        StrokeThickness="0"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.08" Radius="10" Offset="0,2"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0" Padding="5">

                        <!-- Mayo -->
                        <Grid Padding="15,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    WidthRequest="40" HeightRequest="40"
                                    StrokeThickness="0"
                                    BackgroundColor="#E8F5E9"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="💵" FontSize="18" 
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Mayo 2026" FontSize="14" FontAttributes="Bold" TextColor="#212121"/>
                                <Label Text="8 rentas completadas" FontSize="11" TextColor="#9E9E9E"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="$2,500" FontSize="17" 
                                   FontAttributes="Bold" TextColor="#43A047" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F5F5F5" Margin="68,0,15,0"/>

                        <!-- Abril -->
                        <Grid Padding="15,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    WidthRequest="40" HeightRequest="40"
                                    StrokeThickness="0"
                                    BackgroundColor="#E8F5E9"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="💵" FontSize="18" 
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Abril 2026" FontSize="14" FontAttributes="Bold" TextColor="#212121"/>
                                <Label Text="11 rentas completadas" FontSize="11" TextColor="#9E9E9E"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="$3,200" FontSize="17" 
                                   FontAttributes="Bold" TextColor="#43A047" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F5F5F5" Margin="68,0,15,0"/>

                        <!-- Marzo -->
                        <Grid Padding="15,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    WidthRequest="40" HeightRequest="40"
                                    StrokeThickness="0"
                                    BackgroundColor="#E8F5E9"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="💵" FontSize="18" 
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Marzo 2026" FontSize="14" FontAttributes="Bold" TextColor="#212121"/>
                                <Label Text="7 rentas completadas" FontSize="11" TextColor="#9E9E9E"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="$2,100" FontSize="17" 
                                   FontAttributes="Bold" TextColor="#43A047" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F5F5F5" Margin="68,0,15,0"/>

                        <!-- Febrero -->
                        <Grid Padding="15,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    WidthRequest="40" HeightRequest="40"
                                    StrokeThickness="0"
                                    BackgroundColor="#E8F5E9"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Label Text="💵" FontSize="18" 
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Febrero 2026" FontSize="14" FontAttributes="Bold" TextColor="#212121"/>
                                <Label Text="6 rentas completadas" FontSize="11" TextColor="#9E9E9E"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="$1,850" FontSize="17" 
                                   FontAttributes="Bold" TextColor="#43A047" VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Sección: Vehículos Top -->
                <Label Text="🏆 VEHÍCULOS MÁS RENTABLES" 
                       FontSize="12" 
                       FontAttributes="Bold"
                       TextColor="#9E9E9E"
                       CharacterSpacing="2"
                       Margin="25,5,20,8"/>

                <Border Margin="20,0,20,15" 
                        Padding="0"
                        StrokeThickness="0"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.08" Radius="10" Offset="0,2"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">

                        <!-- Top 1 -->
                        <Grid Padding="15" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10">
                            <Border Grid.Column="0"
                                    WidthRequest="32" HeightRequest="32"
                                    StrokeThickness="0"
                                    BackgroundColor="#FFD700"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16"/>
                                </Border.StrokeShape>
                                <Label Text="1" FontSize="14" FontAttributes="Bold" 
                                       TextColor="White" 
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Border Grid.Column="1"
                                    WidthRequest="50" HeightRequest="50"
                                    StrokeThickness="0"
                                    BackgroundColor="#FFF3E0"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="🚐" FontSize="26" 
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                                <Label Text="Honda CR-V 2024" FontSize="14" FontAttributes="Bold" TextColor="#212121"/>
                                <Label Text="18 rentas • $48/día" FontSize="11" TextColor="#9E9E9E"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="3" Text="$864" FontSize="16" 
                                   FontAttributes="Bold" TextColor="#43A047" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F5F5F5" Margin="60,0,15,0"/>

                        <!-- Top 2 -->
                        <Grid Padding="15" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10">
                            <Border Grid.Column="0"
                                    WidthRequest="32" HeightRequest="32"
                                    StrokeThickness="0"
                                    BackgroundColor="#C0C0C0"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16"/>
                                </Border.StrokeShape>
                                <Label Text="2" FontSize="14" FontAttributes="Bold" 
                                       TextColor="White" 
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Border Grid.Column="1"
                                    WidthRequest="50" HeightRequest="50"
                                    StrokeThickness="0"
                                    BackgroundColor="#E3F2FD"
                                    VerticalOptions="Center">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="🚙" FontSize="26" 
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                                <Label Text="Toyota Corolla 2024" FontSize="14" FontAttributes="Bold" TextColor="#212121"/>
                                <Label Text="24 rentas • $35/día" FontSize="11" TextColor="#9E9E9E"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="3" Text="$840" FontSize="16" 
                                   FontAttributes="Bold" TextColor="#43A047" VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Botón retiro -->
                <Border Margin="20,15,20,30"
                        StrokeThickness="0"
                        HeightRequest="55">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#2E7D32" Opacity="0.4" Radius="12" Offset="0,4"/>
                    </Border.Shadow>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#43A047" Offset="0.0"/>
                            <GradientStop Color="#2E7D32" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Button Text="💸 Solicitar Retiro de Fondos"
                            BackgroundColor="Transparent"
                            TextColor="White"
                            FontSize="15"
                            FontAttributes="Bold"
                            Clicked="OnWithdrawClicked"/>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
