<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AUTORENT.ViewModels"
             xmlns:converters="clr-namespace:AUTORENT.Converters"
             x:Class="AUTORENT.Pages.OwnerEarningsPage"
             x:DataType="viewmodels:OwnerEarningsViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F9FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*">
        <RefreshView IsRefreshing="{Binding IsBusy}"
                     Command="{Binding RefreshCommand}"
                     RefreshColor="#43A047">
            <ScrollView>
                <VerticalStackLayout Spacing="0">

                    <!-- Header con gradiente VERDE -->
                    <Grid HeightRequest="280">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#43A047" Offset="0.0" />
                                <GradientStop Color="#2E7D32" Offset="0.5" />
                                <GradientStop Color="#1B5E20" Offset="1.0" />
                            </LinearGradientBrush>
                        </Grid.Background>

                        <Ellipse Fill="#FFFFFF" 
                                 Opacity="0.1"
                                 WidthRequest="200" 
                                 HeightRequest="200"
                                 HorizontalOptions="End"
                                 VerticalOptions="Start"
                                 Margin="0,-50,-50,0"/>
                        <Ellipse Fill="#FFFFFF" 
                                 Opacity="0.08"
                                 WidthRequest="150" 
                                 HeightRequest="150"
                                 HorizontalOptions="Start"
                                 VerticalOptions="End"
                                 Margin="-30,0,0,-30"/>

                        <Grid ColumnDefinitions="Auto,*" 
                              RowDefinitions="Auto,*"
                              Padding="20,50,20,20">

                            <Border Grid.Row="0" Grid.Column="0"
                                    StrokeThickness="0"
                                    BackgroundColor="#33FFFFFF"
                                    WidthRequest="42"
                                    HeightRequest="42">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="21"/>
                                </Border.StrokeShape>
                                <Label Text="←"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>

                            <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" 
                                                 VerticalOptions="Center"
                                                 Spacing="6"
                                                 Margin="0,30,0,0">
                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                    <Label Text="💰" FontSize="20"/>
                                    <Label Text="GANANCIAS TOTALES" 
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="#C8E6C9"
                                           CharacterSpacing="2"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Label HorizontalOptions="Start">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="$" 
                                                  FontSize="28" 
                                                  TextColor="White"
                                                  FontAttributes="Bold"/>
                                            <Span Text="{Binding TotalEarningsFormatted}" 
                                                  FontSize="48" 
                                                  TextColor="White"
                                                  FontAttributes="Bold"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Text="{Binding TrendText}" 
                                       FontSize="13"
                                       TextColor="#A5D6A7"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>

                    <!-- Stats Cards -->
                    <Grid ColumnDefinitions="*,*" 
                          ColumnSpacing="10"
                          Margin="20,-40,20,15"
                          HeightRequest="100">

                        <Border Grid.Column="0"
                                StrokeThickness="0"
                                BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Opacity="0.12" Radius="12" Offset="0,3"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="3" 
                                                 VerticalOptions="Center"
                                                 Padding="12">
                                <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                                    <Label Text="📈" FontSize="18"/>
                                    <Label Text="Este mes" 
                                           FontSize="11"
                                           TextColor="#757575"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Label Text="{Binding CurrentMonthEarningsFormatted}" 
                                       FontSize="22" 
                                       FontAttributes="Bold"
                                       TextColor="#43A047"
                                       HorizontalOptions="Center"/>
                                <Label FontSize="10"
                                       TextColor="#757575"
                                       HorizontalOptions="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding CurrentMonthRentals}"/>
                                            <Span Text=" rentas"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1"
                                StrokeThickness="0"
                                BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Opacity="0.12" Radius="12" Offset="0,3"/>
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="3" 
                                                 VerticalOptions="Center"
                                                 Padding="12">
                                <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                                    <Label Text="⏳" FontSize="18"/>
                                    <Label Text="Pendiente" 
                                           FontSize="11"
                                           TextColor="#757575"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Label Text="{Binding PendingEarningsFormatted}" 
                                       FontSize="22" 
                                       FontAttributes="Bold"
                                       TextColor="#FF9800"
                                       HorizontalOptions="Center"/>
                                <Label Text="{Binding PendingRentalsText}" 
                                       FontSize="10"
                                       TextColor="#9E9E9E"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Sección: Histórico Mensual -->
                    <Label Text="📊 HISTÓRICO MENSUAL" 
                           FontSize="12" 
                           FontAttributes="Bold"
                           TextColor="#9E9E9E"
                           CharacterSpacing="2"
                           Margin="25,5,20,8"/>

                    <Border Margin="20,0,20,15" 
                            Padding="0"
                            StrokeThickness="0"
                            BackgroundColor="White"
                            IsVisible="{Binding HasMonthlyHistory}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.08" Radius="10" Offset="0,2"/>
                        </Border.Shadow>
                        <CollectionView ItemsSource="{Binding MonthlyHistory}"
                                        ItemSizingStrategy="MeasureFirstItem">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="0"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:MonthlyEarning">
                                    <VerticalStackLayout>
                                        <Grid Padding="15,12" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                            <Border Grid.Column="0"
                                                    WidthRequest="40" HeightRequest="40"
                                                    StrokeThickness="0"
                                                    BackgroundColor="#E8F5E9"
                                                    VerticalOptions="Center">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Label Text="💵" FontSize="18" 
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding Month}" 
                                                       FontSize="14" 
                                                       FontAttributes="Bold" 
                                                       TextColor="#212121"
                                                       TextTransform="None"/>
                                                <Label Text="{Binding RentalsText}" 
                                                       FontSize="11" 
                                                       TextColor="#9E9E9E"/>
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2" 
                                                   Text="{Binding EarningsFormatted}" 
                                                   FontSize="17" 
                                                   FontAttributes="Bold" 
                                                   TextColor="{Binding EarningsColor}"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                        <BoxView HeightRequest="1" BackgroundColor="#F5F5F5" Margin="68,0,15,0"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>

                    <!-- Sección: Top Vehículos -->
                    <VerticalStackLayout IsVisible="{Binding HasTopVehicles}">
                        <Label Text="🏆 VEHÍCULOS MÁS RENTABLES" 
                               FontSize="12" 
                               FontAttributes="Bold"
                               TextColor="#9E9E9E"
                               CharacterSpacing="2"
                               Margin="25,5,20,8"/>

                        <Border Margin="20,0,20,15" 
                                Padding="0"
                                StrokeThickness="0"
                                BackgroundColor="White">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Opacity="0.08" Radius="10" Offset="0,2"/>
                            </Border.Shadow>
                            <CollectionView ItemsSource="{Binding TopVehicles}"
                                            ItemSizingStrategy="MeasureFirstItem">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="0"/>
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:TopVehicle">
                                        <VerticalStackLayout>
                                            <Grid Padding="15" 
                                                  ColumnDefinitions="Auto,Auto,*,Auto" 
                                                  ColumnSpacing="10">
                                                <Border Grid.Column="0"
                                                        WidthRequest="32" HeightRequest="32"
                                                        StrokeThickness="0"
                                                        BackgroundColor="{Binding RankColor}"
                                                        VerticalOptions="Center">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="16"/>
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding Rank}" 
                                                           FontSize="14" 
                                                           FontAttributes="Bold" 
                                                           TextColor="White" 
                                                           HorizontalOptions="Center" 
                                                           VerticalOptions="Center"/>
                                                </Border>
                                                <Border Grid.Column="1"
                                                        WidthRequest="50" HeightRequest="50"
                                                        StrokeThickness="0"
                                                        BackgroundColor="#E3F2FD"
                                                        VerticalOptions="Center">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="12"/>
                                                    </Border.StrokeShape>
                                                    <Label Text="{Binding Emoji}" 
                                                           FontSize="26" 
                                                           HorizontalOptions="Center" 
                                                           VerticalOptions="Center"/>
                                                </Border>
                                                <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                                                    <Label Text="{Binding VehicleName}" 
                                                           FontSize="14" 
                                                           FontAttributes="Bold" 
                                                           TextColor="#212121"
                                                           LineBreakMode="TailTruncation"/>
                                                    <Label Text="{Binding SubtitleText}" 
                                                           FontSize="11" 
                                                           TextColor="#9E9E9E"/>
                                                </VerticalStackLayout>
                                                <Label Grid.Column="3" 
                                                       Text="{Binding TotalFormatted}" 
                                                       FontSize="16" 
                                                       FontAttributes="Bold" 
                                                       TextColor="#43A047" 
                                                       VerticalOptions="Center"/>
                                            </Grid>
                                            <BoxView HeightRequest="1" 
                                                     BackgroundColor="#F5F5F5" 
                                                     Margin="60,0,15,0"/>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Estado vacío -->
                    <VerticalStackLayout IsVisible="{Binding HasEarnings, Converter={StaticResource InvertedBoolConverter}}"
                                         Padding="30,40"
                                         Spacing="15"
                                         HorizontalOptions="Center">
                        <Border WidthRequest="100"
                                HeightRequest="100"
                                StrokeThickness="0"
                                BackgroundColor="#E8F5E9"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="50"/>
                            </Border.StrokeShape>
                            <Label Text="💰" 
                                   FontSize="50"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <Label Text="Sin ganancias todavía" 
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#212121"
                               HorizontalOptions="Center"/>
                        <Label Text="Tus ganancias aparecerán aquí cuando completes rentas" 
                               FontSize="13"
                               TextColor="#757575"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>

                    <!-- Botón retiro -->
                    <Border Margin="20,15,20,30"
                            StrokeThickness="0"
                            HeightRequest="55"
                            IsVisible="{Binding HasEarnings}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#2E7D32" Opacity="0.4" Radius="12" Offset="0,4"/>
                        </Border.Shadow>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#43A047" Offset="0.0"/>
                                <GradientStop Color="#2E7D32" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Button Text="💸 Solicitar Retiro de Fondos"
                                Command="{Binding WithdrawCommand}"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontSize="15"
                                FontAttributes="Bold"/>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>

</ContentPage>
