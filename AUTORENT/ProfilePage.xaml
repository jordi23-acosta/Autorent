<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AUTORENT.ViewModels"
             xmlns:converters="clr-namespace:AUTORENT.Converters"
             x:Class="AUTORENT.ProfilePage"
             x:DataType="viewmodels:ProfileViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F8F9FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0" x:Name="MainContainer">

            <!-- Header con gradiente -->
            <Grid HeightRequest="280">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E88E5" Offset="0.0" />
                        <GradientStop Color="#1565C0" Offset="0.5" />
                        <GradientStop Color="#0D47A1" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>

                <!-- Círculos decorativos -->
                <Ellipse Fill="#FFFFFF" 
                         Opacity="0.1"
                         WidthRequest="200" 
                         HeightRequest="200"
                         HorizontalOptions="End"
                         VerticalOptions="Start"
                         Margin="0,-50,-50,0"/>
                <Ellipse Fill="#FFFFFF" 
                         Opacity="0.08"
                         WidthRequest="150" 
                         HeightRequest="150"
                         HorizontalOptions="Start"
                         VerticalOptions="End"
                         Margin="-30,0,0,-30"/>

                <VerticalStackLayout VerticalOptions="Center" 
                                     Spacing="10" 
                                     Padding="20,40,20,20">
                    
                    <!-- Avatar con iniciales -->
                    <Border WidthRequest="100" 
                            HeightRequest="100"
                            StrokeThickness="4"
                            Stroke="White"
                            BackgroundColor="#0D47A1"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="50"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="Black" 
                                    Opacity="0.3" 
                                    Radius="15" 
                                    Offset="0,5"/>
                        </Border.Shadow>
                        <Label Text="{Binding UserInitials}" 
                               FontSize="36" 
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <!-- Nombre del usuario -->
                    <Label Text="{Binding UserName}" 
                           FontSize="24" 
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"/>

                    <!-- Email -->
                    <Label Text="{Binding UserEmail}" 
                           FontSize="13"
                           TextColor="#E3F2FD"
                           HorizontalOptions="Center"/>

                    <!-- Badge de rol -->
                    <Border StrokeThickness="0"
                            Padding="14,6"
                            BackgroundColor="#33FFFFFF"
                            HorizontalOptions="Center"
                            Margin="0,5,0,0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <HorizontalStackLayout Spacing="6">
                            <Label FontSize="13" 
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" 
                                                 Binding="{Binding IsOwner}" 
                                                 Value="True">
                                        <Setter Property="Text" Value="🏠"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" 
                                                 Binding="{Binding IsOwner}" 
                                                 Value="False">
                                        <Setter Property="Text" Value="🚗"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Label Text="{Binding UserRole}" 
                                   FontSize="12"
                                   TextColor="White"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Grid>

            <!-- Estadísticas (3 cards flotantes) -->
            <Grid ColumnDefinitions="*,*,*" 
                  ColumnSpacing="10"
                  Margin="20,-35,20,15"
                  HeightRequest="100">

                <!-- Stat 1: Rentas -->
                <Border Grid.Column="0"
                        StrokeThickness="0"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" 
                                Opacity="0.12" 
                                Radius="12" 
                                Offset="0,3"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="3" 
                                         VerticalOptions="Center"
                                         Padding="10">
                        <Label Text="🚙" 
                               FontSize="20"
                               HorizontalOptions="Center"/>
                        <Label Text="{Binding TotalRentals}" 
                               FontSize="22" 
                               FontAttributes="Bold"
                               TextColor="#1E88E5"
                               HorizontalOptions="Center"/>
                        <Label Text="Rentas" 
                               FontSize="11"
                               TextColor="#757575"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Stat 2: Vehículos (solo Owner) o Favoritos -->
                <Border Grid.Column="1"
                        StrokeThickness="0"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" 
                                Opacity="0.12" 
                                Radius="12" 
                                Offset="0,3"/>
                    </Border.Shadow>
                    <Grid>
                        <!-- Si es Owner: mostrar Vehículos -->
                        <VerticalStackLayout Spacing="3" 
                                             VerticalOptions="Center"
                                             Padding="10"
                                             IsVisible="{Binding IsOwner}">
                            <Label Text="🏠" 
                                   FontSize="20"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding TotalVehicles}" 
                                   FontSize="22" 
                                   FontAttributes="Bold"
                                   TextColor="#FF9800"
                                   HorizontalOptions="Center"/>
                            <Label Text="Vehículos" 
                                   FontSize="11"
                                   TextColor="#757575"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        
                        <!-- Si NO es Owner: mostrar Favoritos -->
                        <VerticalStackLayout Spacing="3" 
                                             VerticalOptions="Center"
                                             Padding="10"
                                             IsVisible="{Binding IsOwner, Converter={StaticResource InvertedBoolConverter}}">
                            <Label Text="❤️" 
                                   FontSize="20"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding TotalFavorites}" 
                                   FontSize="22" 
                                   FontAttributes="Bold"
                                   TextColor="#E91E63"
                                   HorizontalOptions="Center"/>
                            <Label Text="Favoritos" 
                                   FontSize="11"
                                   TextColor="#757575"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Stat 3: Rating -->
                <Border Grid.Column="2"
                        StrokeThickness="0"
                        BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" 
                                Opacity="0.12" 
                                Radius="12" 
                                Offset="0,3"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="3" 
                                         VerticalOptions="Center"
                                         Padding="10">
                        <Label Text="⭐" 
                               FontSize="20"
                               HorizontalOptions="Center"/>
                        <Label Text="5.0" 
                               FontSize="22" 
                               FontAttributes="Bold"
                               TextColor="#FFC107"
                               HorizontalOptions="Center"/>
                        <Label Text="Rating" 
                               FontSize="11"
                               TextColor="#757575"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Sección: Mi Cuenta -->
            <Label Text="MI CUENTA" 
                   FontSize="12" 
                   FontAttributes="Bold"
                   TextColor="#9E9E9E"
                   CharacterSpacing="2"
                   Margin="25,15,20,8"/>

            <Border Margin="20,0,20,15" 
                    Padding="0"
                    StrokeThickness="0"
                    BackgroundColor="White">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" 
                            Opacity="0.08" 
                            Radius="10" 
                            Offset="0,2"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">

                    <!-- Editar Nombre -->
                    <Grid Padding="18,15" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding PersonalInfoCommand}"/>
                        </Grid.GestureRecognizers>
                        <Border Grid.Column="0"
                                WidthRequest="40"
                                HeightRequest="40"
                                StrokeThickness="0"
                                BackgroundColor="#E3F2FD">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="👤" 
                                   FontSize="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" 
                                             Spacing="2"
                                             VerticalOptions="Center">
                            <Label Text="Nombre" 
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#212121"/>
                            <Label Text="{Binding UserName}" 
                                   FontSize="12"
                                   TextColor="#757575"
                                   LineBreakMode="TailTruncation"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" 
                               Text="✏️" 
                               FontSize="16"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" 
                             BackgroundColor="#F5F5F5"
                             Margin="73,0,18,0"/>

                    <!-- Email (no editable) -->
                    <Grid Padding="18,15" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                        <Border Grid.Column="0"
                                WidthRequest="40"
                                HeightRequest="40"
                                StrokeThickness="0"
                                BackgroundColor="#E8F5E9">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="📧" 
                                   FontSize="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" 
                                             Spacing="2"
                                             VerticalOptions="Center">
                            <Label Text="Email" 
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#212121"/>
                            <Label Text="{Binding UserEmail}" 
                                   FontSize="12"
                                   TextColor="#757575"
                                   LineBreakMode="TailTruncation"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" 
                               Text="🔒" 
                               FontSize="14"
                               TextColor="#9E9E9E"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" 
                             BackgroundColor="#F5F5F5"
                             Margin="73,0,18,0"/>

                    <!-- Teléfono -->
                    <Grid Padding="18,15" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding EditPhoneCommand}"/>
                        </Grid.GestureRecognizers>
                        <Border Grid.Column="0"
                                WidthRequest="40"
                                HeightRequest="40"
                                StrokeThickness="0"
                                BackgroundColor="#FFF3E0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="📱" 
                                   FontSize="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" 
                                             Spacing="2"
                                             VerticalOptions="Center">
                            <Label Text="Teléfono" 
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#212121"/>
                            <Label Text="{Binding UserPhone}" 
                                   FontSize="12"
                                   TextColor="#757575"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" 
                               Text="✏️" 
                               FontSize="16"
                               VerticalOptions="Center"/>
                    </Grid>

                    <!-- Divider -->
                    <BoxView HeightRequest="1" 
                             BackgroundColor="#F5F5F5"
                             Margin="73,0,18,0"/>

                    <!-- Cambiar Contraseña -->
                    <Grid Padding="18,15" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ChangePasswordCommand}"/>
                        </Grid.GestureRecognizers>
                        <Border Grid.Column="0"
                                WidthRequest="40"
                                HeightRequest="40"
                                StrokeThickness="0"
                                BackgroundColor="#FFEBEE">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="🔐" 
                                   FontSize="20"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" 
                                             Spacing="2"
                                             VerticalOptions="Center">
                            <Label Text="Contraseña" 
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#212121"/>
                            <Label Text="Cambia tu contraseña" 
                                   FontSize="12"
                                   TextColor="#757575"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" 
                               Text="›" 
                               FontSize="22"
                               TextColor="#BDBDBD"
                               VerticalOptions="Center"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Botón de cerrar sesión -->
            <Border Margin="20,10,20,20"
                    StrokeThickness="2"
                    Stroke="#F44336"
                    BackgroundColor="Transparent"
                    HeightRequest="55">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Button Text="🚪 Cerrar Sesión"
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#F44336"
                        FontAttributes="Bold"
                        FontSize="15"/>
            </Border>

            <!-- Footer -->
            <Label Text="{Binding MemberSince}"
                   FontSize="11"
                   TextColor="#9E9E9E"
                   HorizontalOptions="Center"
                   Margin="0,5,0,30"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
