<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AUTORENT.RentalsPage"
             Title="Mis Rentas"
             BackgroundColor="{DynamicResource PageBackground}">

    <Grid RowDefinitions="Auto,*" Padding="0">
        
        <!-- Header -->
        <BoxView Grid.Row="0" HeightRequest="120" BackgroundColor="{StaticResource Primary}"/>
        <VerticalStackLayout Grid.Row="0" Padding="20" VerticalOptions="Center">
            <Label Text="Mis Rentas" 
                   FontSize="28" 
                   FontAttributes="Bold"
                   TextColor="White"/>
            <Label Text="Gestiona tus reservaciones" 
                   FontSize="14"
                   TextColor="{StaticResource PrimaryDarkText}"
                   Margin="0,5,0,0"/>
        </VerticalStackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="1" Margin="0,-20,0,0">
            <VerticalStackLayout x:Name="ContentArea" Spacing="15" Padding="20">
                <!-- Las rentas se cargarán dinámicamente aquí -->
            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
